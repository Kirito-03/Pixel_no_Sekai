{
  "expo": {
    "scheme": "pixelnosekai",
    "name": "Pixel No Sekai",
    "slug": "pixel-no-sekai",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon-arle.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon-arle.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-arle.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.dragonflux.pixelnosekai",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/icon-arle.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-google-signin/google-signin"
    ]
  }
}
