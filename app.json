{
  "expo": {
    "scheme": "netflixapp",
    "name": "Proyecto_Netflix",
    "slug": "Proyecto_Netflix",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon-arle.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon-arle.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-arle.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Proyecto_Netflix"
    },
    "web": {
      "favicon": "./assets/icon-arle.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}